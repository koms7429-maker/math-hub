    "clues": [
      {
        "id": "단서A",
        "text": "방정식 $(x-m^n)(x^n-m)=0$이 주어진다"
      },
      {
        "id": "단서B",
        "text": "$2 \\leq n \\leq 6$인 자연수 $n$이다"
      },
      {
        "id": "단서C",
        "text": "$-3 \\leq m \\leq 3$인 정수 $m$이다"
      },
      {
        "id": "단서D",
        "text": "서로 다른 실근의 개수가 1이다"
      }
    ],
    "skeleton": [
      {
        "from": "단서A",
        "to": "연산9",
        "note": "방정식 $(x-m^n)(x^n-m)=0$은 $x=m^n$ 또는 $x^n=m$을 만족한다"
      },
      {
        "from": "연산9",
        "to": "전략12",
        "note": "$x^n=m$의 실근 개수는 $n$의 홀짝과 $m$의 부호에 따라 달라진다"
      },
      {
        "from": "전략12",
        "to": "사실4",
        "note": "$n$이 홀수이면 실근 1개, $n$이 짝수이고 $m>0$이면 실근 2개, $m=0$이면 실근 1개, $m<0$이면 실근 0개이다"
      },
      {
        "from": [
          "연산9",
          "사실4"
        ],
        "to": "전략6",
        "note": "$n$의 홀짝과 $m$의 부호로 4가지 경우로 분류한다"
      },
      {
        "from": "전략6",
        "to": "전략6_1",
        "note": "경우①: $n$이 홀수일 때 실근은 $m^n$, $\\sqrt[n]{m}$이다"
      },
      {
        "from": "전략6",
        "to": "전략6_2",
        "note": "경우②: $n$이 짝수이고 $m<0$일 때 실근은 $m^n$ 하나이다"
      },
      {
        "from": "전략6",
        "to": "전략6_3",
        "note": "경우③: $n$이 짝수이고 $m=0$일 때 실근은 $0$ 하나이다"
      },
      {
        "from": "전략6",
        "to": "전략6_4",
        "note": "경우④: $n$이 짝수이고 $m>0$일 때 실근은 $m^n$, $\\sqrt[n]{m}$, $-\\sqrt[n]{m}$이다"
      },
      {
        "from": "전략6_1",
        "to": "전략2",
        "note": "서로 다른 실근이 1개이려면 $m^n = \\sqrt[n]{m}$이어야 한다"
      },
      {
        "from": "전략2",
        "to": "전략17",
        "note": "$m^n = \\sqrt[n]{m}$을 만족하는 정수 $m$을 전수조사한다"
      },
      {
        "from": "전략17",
        "to": "전략17_1",
        "note": "$m = -1, 0, 1$일 때만 $m^n = \\sqrt[n]{m}$이 성립한다"
      },
      {
        "from": [
          "전략17_1",
