  "clues": [
    {
      "id": "단서A",
      "text": "$x$에 대한 방정식 $(x^n-2^{25})(x^{2n}-2^{20})=0$"
    },
    {
      "id": "단서B",
      "text": "서로 다른 모든 실근의 곱은 $-100$보다 큰 정수이다"
    },
    {
      "id": "단서C",
      "text": "$n$은 $2$ 이상의 자연수이다"
    }
  ],
  "skeleton": [
    {
      "from": "단서A",
      "to": "note1",
      "neuron": "전략29",
      "note": "$x^{2n}-2^{20}=(x^n)^2-(2^{10})^2=(x^n-2^{10})(x^n+2^{10})$으로 인수분해된다",
      "step": 1
    },
    {
      "from": "note1",
      "to": "note2",
      "neuron": "연산9",
      "note": "$(x^n-2^{25})(x^n-2^{10})(x^n+2^{10})=0$에서 $x^n=2^{25}$ 또는 $x^n=2^{10}$ 또는 $x^n=-2^{10}$이다",
      "step": 1
    },
    {
      "from": [
        "note2",
        "단서C"
      ],
      "to": "note3",
      "neuron": "전략12",
      "note": "$n$이 홀수인 경우와 짝수인 경우로 나누어 실근을 구한다",
      "step": 2
    },
    {
      "from": "note3",
      "to": "note4",
      "neuron": "사실4",
      "note": "$n$이 홀수일 때 $x^n=c$는 임의의 실수 $c$에 대해 실근을 정확히 1개 가진다",
      "step": 2
    },
    {
      "from": "note4",
      "to": "note5",
      "neuron": "연산4",
      "note": "세 실근은 $x=2^{25/n}$, $x=2^{10/n}$, $x=-2^{10/n}$이다",
      "step": 2
    },
    {
      "from": "note5",
      "to": "note6",
      "neuron": "사실58",
      "note": "$2^{25}\\neq 2^{10}\\neq -2^{10}$이고 $x\\mapsto x^n$이 단사이므로 세 근은 서로 다르다",
      "main": false,
      "step": 2
    },
    {
      "from": "note5",
      "to": "note7",
      "neuron": "연산18",
      "note": "모든 실근의 곱은 $2^{25/n}\\cdot 2^{10/n}\\cdot(-2^{10/n})=-2^{45/n}$이다",
      "step": 2
