  "clues": [
    {
      "id": "단서A",
      "text": "$f(x)=\\frac{1}{16}\\{(x-3)^2+n\\}$이고 $n$은 $n\\neq 12$인 자연수이다"
    },
    {
      "id": "단서B",
      "text": "$\\log_{f(1)}f(x)\\geq\\log_{f(1)}\\left(\\frac{n+1}{8}\\right)$의 실근 중 정수인 것의 개수가 7이다"
    }
  ],
  "skeleton": [
