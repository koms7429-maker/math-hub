  {
    "problem_id": "Problem2(Unknown)-LogarithmandSetTheory",
    "answer": "81",
    "clues": [
      {
        "id": "단서A",
        "text": "$A = \\{x \\mid x\\text{는 실수}\\}$ (전체 실수 집합)"
      },
      {
        "id": "단서B",
        "text": "$B = \\{x \\mid \\log|4^x - 3| \\times \\log f(x) \\geq 0\\}$"
      },
      {
        "id": "단서C",
        "text": "$f(x)$는 이차함수이다"
      },
      {
        "id": "단서D",
        "text": "$n(A - B) = 2$"
      }
    ],
    "skeleton": [
      {
        "from": "단서B",
        "to": "사실59",
        "note": "log|4^x-3|, logf(x)가 정의되려면 |4^x-3|>0이고 f(x)>0이어야 한다",
        "main": true
      },
      {
        "from": [
          "단서B",
          "사실59"
        ],
        "to": "전략30",
        "note": "log|4^x-3|×logf(x)≥0은 (|4^x-3|-1)(f(x)-1)≥0과 동치이다",
        "main": true
      },
      {
        "from": "사실59",
        "to": "연산9",
        "note": "|4^x-3|=0인 x=log₄3은 진수조건 위반으로 A-B의 원소이다",
        "main": true
      },
      {
        "from": [
          "전략30",
          "연산9"
        ],
        "to": "전략27",
        "note": "A-B = {x=log₄3} ∪ {f(x)≤0인 x} ∪ {(|4^x-3|-1)(f(x)-1)<0인 x}이고, n(A-B)=2인 조건에서 무한집합을 만드는 시나리오를 배제한다",
        "main": true
      },
      {
        "from": [
          "전략27",
          "단서D"
        ],
        "to": "전략22",
        "note": "f(x)=0의 근이 정확히 1개(이중근)이고 그 근이 log₄3이 아닌 경우와, 모든 x에서 (|4^x-3|-1)(f(x)-1)≥0인 경우로 분류한다",
        "main": true
      },
      {
        "from": "전략22",
        "to": "전략6",
        "note": "|4^x-3|≥1을 절댓값 부호 분리하면 x≤1/2 또는 x≥1이고, 1/2<x<1에서 |4^x-3|<1이다",
        "main": true
      },
      {
        "from": "전략6",
        "to": "사실72",
        "note": "x≤1/2, x≥1일 때 f(x)≥1이고 1/2<x<1일 때 f(x)≤1인 조건에서 f(1/2)=f(1)=1을 만족하는 이차함수는 f(x)=k(x-1/2)(x-1)+1 (k>0)이다",
        "main": true
      },
      {
