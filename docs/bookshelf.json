        "note_id": "note25",
        "neuron": "전략25",
        "hint_level": 3,
        "text": "$\\mathrm{C}(1,\\,\\sqrt{2})$를 $y=\\log_a(b-x)=\\log_a(3-x)$에 대입하면 $\\sqrt{2}=\\log_a 2$이다",
        "from": [
          "note24"
        ],
        "main": true
      }
