        "main": true
      },
      {
        "from": "단서B",
        "to": "note3",
        "neuron": "전략27",
        "note": "$f(x)<0$인 $x$는 없거나 무수히 많고, $(|4^x-3|-1)(f(x)-1)<0$인 $x$도 없거나 무수히 많다",
        "main": false
