      "note": "$\\log_n 1 = 0$이고 $\\dfrac{1}{2} < 1$이므로 $\\log_n \\dfrac{1}{2} < 0$이다",
      "main": false,
      "step": 2
    },
    {
      "from": [
        "note3",
