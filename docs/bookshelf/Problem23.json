  "clues": [
    {
      "id": "단서A",
      "text": "$f(x) = -9(x-a)(x-b)$, $a < b$, $a$, $b$는 자연수"
    },
    {
      "id": "단서B",
      "text": "$g(x) = x - 3$"
    },
    {
      "id": "단서C",
      "text": "$\\log_4 f(x) + \\log_{\\frac{1}{2}} g(x) \\geq \\frac{1}{2}$"
    },
    {
      "id": "단서D",
      "text": "부등식을 만족시키는 모든 실수 $x$의 값의 범위가 $3 < x \\leq 9$이다"
    }
  ],
  "skeleton": [
    {
