  "skeleton": [
    {
      "from": "단서A",
      "to": "note1",
      "neuron": "전략28",
      "note": "$f(x) = \\log_2 x$, $g(x) = 6\\log_n \\left| x - \\dfrac{11}{2} \\right|$로 놓으면 부등식은 $f(x) > g(x)$이다",
      "step": 1
    },
    {
      "from": "note1",
      "to": "note2",
      "neuron": "사실2",
      "note": "$g(x) = 6\\log_n\\left|x - \\dfrac{11}{2}\\right|$는 $x = \\dfrac{11}{2}$에 대해 대칭이다. 자연수에서 $g(k) = g(11-k)$이므로 $g(5)=g(6)$, $g(4)=g(7)$, $g(3)=g(8)$, $g(2)=g(9)$, $g(1)=g(10)$이다",
      "step": 1
    },
    {
      "from": "note2",
      "to": "note3",
      "neuron": "전략25",
      "note": "$\\left|5 - \\dfrac{11}{2}\\right| = \\left|6 - \\dfrac{11}{2}\\right| = \\dfrac{1}{2}$, $\\left|4 - \\dfrac{11}{2}\\right| = \\left|7 - \\dfrac{11}{2}\\right| = \\dfrac{3}{2}$, $\\left|3 - \\dfrac{11}{2}\\right| = \\left|8 - \\dfrac{11}{2}\\right| = \\dfrac{5}{2}$이다",
      "step": 1
    },
    {
      "from": "단서B",
      "to": "note4",
      "neuron": "사실12",
      "note": "$n \\geq 2 > 1$일 때 $\\log_n x$는 순증가이다",
      "main": false,
      "step": 2
    },
    {
      "from": [
        "note4",
        "사실62"
      ],
      "to": "note5",
