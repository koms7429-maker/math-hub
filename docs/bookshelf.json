        "main": true
      },
      {
        "note_id": "note16",
        "neuron": "연산2",
        "hint_level": 1,
        "text": "$b^x=a$에서 $x=\\log_b a$이므로 $B(\\log_b a,\\,a)$이다",
        "from": [
          "단서B",
          "단서C"
        ],
        "main": true
      },
      {
        "note_id": "note18",
        "neuron": "전략2",
        "hint_level": 2,
        "text": "$\\frac{3a^2}{5}=10\\cdot\\frac{1}{2}\\cdot\\log_b a\\cdot\\frac{3a}{5}$에서 $\\log_b a=\\frac{a}{5}$이다",
        "from": [
