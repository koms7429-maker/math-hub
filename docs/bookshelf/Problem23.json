    },
    {
      "from": "note10",
      "to": "note11",
      "neuron": "사실35",
      "note": "$x^2$ 계수가 $-11 < 0$이므로 $h(x) \\geq 0$의 해 집합은 두 근 $x_1 \\leq x_2$에 대해 $[x_1, x_2]$이다",
      "step": 3
    },
    {
      "from": [
