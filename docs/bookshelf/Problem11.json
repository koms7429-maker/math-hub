      "to": "note8",
      "neuron": "전략37",
      "note": "$-2^{45/n}$이 정수이려면 $2^{45/n}$이 정수여야 하고, $45/n$이 양의 정수여야 한다",
      "step": 2
    },
    {
      "from": "note8",
      "to": "note9",
      "neuron": "사실64",
      "note": "$n\\mid 45$이어야 한다",
      "step": 2
    },
    {
      "from": [
        "note9",
        "단서C"
      ],
      "to": "note10",
      "neuron": "전략33",
      "note": "$45=3^2\\times 5$의 약수 중 $2$ 이상인 홀수는 $3,5,9,15,45$이다",
      "step": 2
    },
    {
      "from": [
        "note7",
        "단서B"
      ],
      "to": "note11",
      "neuron": "연산22",
      "note": "$-2^{45/n}>-100$에서 $2^{45/n}<100$이다",
      "step": 2
