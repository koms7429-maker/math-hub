      "note": "$n=12$를 기준으로, $n>12$이면 $f(1)>1$이고 $1\\leq n\\leq 11$이면 $0<f(1)<1$이다",
      "step": 2
    },
    {
      "from": "note3",
      "to": "note4",
      "neuron": "사실12",
      "note": "$f(1)>1$일 때 $\\log_{f(1)}$은 순증가이다",
      "main": false,
