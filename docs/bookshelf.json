        "id": "단서B",
        "text": "$-\\sqrt[5]{4}$이 어떤 자연수의 $n$제곱근이 된다"
      }
    ],
    "skeleton": [
      {
        "from": "단서B",
        "to": "note1",
        "neuron": "사실74",
        "note": "$-\\sqrt[5]{4} < 0$이므로 음의 $n$제곱근이 존재하려면 $n$이 홀수이거나, 밑이 양수이고 $n$이 짝수이어야 한다. 여기서 자연수의 $n$제곱근이므로 $n$이 짝수이어야 한다",
        "main": true,
        "step": 1
      },
      {
        "from": "단서B",
        "to": "note2",
        "neuron": "사실4",
        "note": "$n$이 짝수일 때 자연수 $a$의 $n$제곱근 중 음수는 $-a^{\\frac{1}{n}}$이다",
        "main": true,
        "step": 2
      },
      {
        "from": "note2",
        "to": "note3",
        "neuron": "전략2",
        "note": "$-a^{\\frac{1}{n}} = -\\sqrt[5]{4}$이므로 $a^{\\frac{1}{n}} = 2^{\\frac{2}{5}}$이다",
        "main": true,
        "step": 2
      },
      {
        "from": "note3",
        "to": "note4",
        "neuron": "연산4",
        "note": "$a = \\left(2^{\\frac{2}{5}}\\right)^n = 2^{\\frac{2n}{5}}$이다",
        "main": true,
        "step": 2
      },
      {
        "from": "note4",
        "to": "note5",
        "neuron": "전략37",
        "note": "$a = 2^{\\frac{2n}{5}}$이 자연수이려면 $\\frac{2n}{5}$이 양의 정수이어야 한다",
        "main": true,
        "step": 3
      },
      {
        "from": "note5",
        "to": "note6",
        "neuron": "사실75",
        "note": "$5 \\mid 2n$이고 $\\gcd(2,5)=1$이므로 $5 \\mid n$이다",
        "main": true,
        "step": 3
      },
      {
        "from": [
          "note1",
